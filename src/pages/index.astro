---
import { getCollection } from "astro:content";
import BaseLayout from "../components/BaseLayout.astro";
import ArtifactCollage from "../components/ArtifactCollage.astro";
import { formatRepoTimestamp, getRepoSnapshots } from "../lib/github";
import "../styles/global.css";
import profilePhoto from "../../assets/PHOTO-2026-04-29-23-03-06.jpg";
import grafanaOverview from "../../assets/Screenshot 2026-05-29 at 1.13.15 PM.png";
import grafanaSettlement from "../../assets/Screenshot 2026-05-29 at 1.13.36 PM.png";
import grafanaSigner from "../../assets/Screenshot 2026-05-29 at 1.14.17 PM.png";
import awsAutoscaleArchitecture from "../../assets/aws-autoscale-architecture.png";

const [profileEntry] = await getCollection("profile");
const [skillsEntry] = await getCollection("skills");
const projectEntries = (await getCollection("featuredProjects")).sort((a, b) => a.data.order - b.data.order);
const caseStudyEntries = await getCollection("caseStudies");

const profile = profileEntry.data;
const skills = skillsEntry.data.domains;
const repoSnapshots = await getRepoSnapshots(projectEntries.map((entry) => entry.data.repo));
const featuredProjects = projectEntries.filter((entry) => entry.data.featured);

const enrichedProjects = featuredProjects.map((entry) => ({
  ...entry.data,
  github: entry.data.repo ? repoSnapshots[entry.data.repo] ?? null : null
}));

const impactSignals = [
  { label: "delivery speed", value: "93%", note: "faster config-only promotions" },
  { label: "payment latency", value: "2.5x", note: "faster end-to-end flow" },
  { label: "migration scale", value: "200+", note: "legacy servers automated" }
];
const operationalSignals = ["SLO-aware deploys", "chaos-gated promotion", "signed image policy", "rollback-ready paths"];
const resumeHref = `${import.meta.env.BASE_URL}resume/amogh-jayasimha-resume.pdf`;
const mediumWriteupHref =
  "https://medium.com/@amoghjay2000/i-built-a-kubernetes-supply-chain-security-demo-heres-why-and-how-2e2f878ef684";

const flagship = enrichedProjects[0];
const supportingProjects = enrichedProjects.slice(1);

const aboutHighlights = [
  "Small to mid-size platform teams where release speed and operational safety are both unsolved at the same time.",
  "Problems that live between infrastructure, developer workflow, and reliability, not deep inside one narrow layer.",
  "Teams that want their platform to stay understandable under pressure, not just functional on a good day."
];

const writingNotes = [
  {
    label: "Published",
    tone: "live",
    title: "Kubernetes supply chain security demo",
    description:
      "Why I built it, how the trust policy works, and what makes it useful as a platform-security reference instead of another throwaway cluster demo.",
    href: mediumWriteupHref,
    cta: "Read on Medium"
  },
  {
    label: "In progress",
    tone: "draft",
    title: "Chaos-gated promotion case study",
    description:
      "A deeper walkthrough of the release gate design, what gets verified before promotion, and the operational tradeoffs behind that model.",
    status: "drafting now"
  },
  {
    label: "Short note",
    tone: "note",
    title: "What good platform work should feel like",
    description:
      "Fast paths for safe changes, rollback behavior that makes sense under pressure, and observability that answers questions before incidents turn into guesswork.",
    status: "living principle"
  }
];

function getPrimaryTools(tools: string[]) {
  return tools.slice(0, 6);
}

const toolIconMap: Record<string, string | null> = {
  "GKE": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/googlecloud/googlecloud-original.svg",
  "AWS": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/amazonwebservices/amazonwebservices-original-wordmark.svg",
  "GCP": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/googlecloud/googlecloud-original.svg",
  "OpenStack": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/openstack/openstack-original.svg",
  "Terraform": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/terraform/terraform-original.svg",
  "Ansible": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/ansible/ansible-original.svg",
  "Packer": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/packer/packer-original.svg",
  "Kubernetes": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/kubernetes/kubernetes-plain.svg",
  "Helm": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/helm/helm-original.svg",
  "KEDA": null,
  "cert-manager": null,
  "ArgoCD": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/argocd/argocd-original.svg",
  "Kargo": null,
  "GitHub Actions": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/githubactions/githubactions-original.svg",
  "OIDC": null,
  "Artifact Registry": null,
  "Prometheus": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/prometheus/prometheus-original.svg",
  "Grafana": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/grafana/grafana-original.svg",
  "Loki": null,
  "CloudWatch": null,
  "Kyverno": null,
  "Cosign": null,
  "Sigstore": "https://cdn.jsdelivr.net/npm/lucide-static@0.542.0/icons/shield-check.svg",
  "External Secrets Operator": null,
  "Workload Identity Federation": null,
  "Secret Manager": null,
  "Python": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg",
  "Go": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/go/go-original.svg",
  "Bash": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/bash/bash-original.svg",
  "PowerShell": null,
  "JavaScript": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg",
  "PostgreSQL": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/postgresql/postgresql-original.svg",
  "Redis": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/redis/redis-original.svg",
  "FastAPI": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/fastapi/fastapi-original.svg",
  "Airflow": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/apacheairflow/apacheairflow-original.svg",
  "SSM": null,
  "RDS": null,
  "Flask": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/flask/flask-original.svg",
  "MySQL": "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original.svg"
};

const supportingArtifacts: Record<string, { src: string; alt: string; caption: string }> = {
  "aws-autoscale-stack": {
    src: awsAutoscaleArchitecture.src,
    alt: "Architecture diagram for the AWS auto-scale stack showing Terraform, Ansible over SSM, ALB, ASG, and RDS.",
    caption: "Architecture diagram spanning Terraform state, SSM-based configuration, ALB, ASG, and RDS."
  }
};

const compactSkills = skills.map((domain) => ({
  ...domain,
  domainIcon:
    {
      "Platform & Cloud": toolIconMap["Terraform"],
      "Kubernetes & Runtime": toolIconMap["Kubernetes"],
      "GitOps / Delivery": toolIconMap["ArgoCD"],
      "Observability & Incident Response": toolIconMap["Prometheus"],
      "Security & Policy": toolIconMap["Sigstore"],
      "Languages & Automation": toolIconMap["Python"]
    }[domain.name] ?? null,
  tools: getPrimaryTools(domain.tools).map((tool) => ({
    name: tool,
    icon: toolIconMap[tool] ?? null
  }))
}));
---

<BaseLayout
  title="Amogh Jayasimha | Platform Engineering, DevOps, and Reliability"
  description="Portfolio of Amogh Jayasimha, a DevOps and SRE engineer focused on Kubernetes platforms, GitOps promotion, reliability engineering, and delivery safety."
>
  <main class="shell">
    <header class="topbar">
      <a class="brand" href="#top">
        <span class="brand__mark">AJ</span>
        <span class="brand__name">{profile.name}</span>
      </a>
      <nav>
        <a href="#about" data-nav-link="about">About</a>
        <a href="#work" data-nav-link="work">Work</a>
        <a href="#experience" data-nav-link="experience">Experience</a>
        <a href="#stack" data-nav-link="stack">Stack</a>
        <a href="#contact" data-nav-link="contact">Contact</a>
      </nav>
      <div class="topbar__actions">
        <a class="topbar__icon" href={profile.links.github} target="_blank" rel="noreferrer" aria-label="GitHub">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@v13/icons/github.svg" alt="" loading="lazy" />
        </a>
        <a class="topbar__icon" href={profile.links.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn">
          <img src="https://cdn.jsdelivr.net/npm/simple-icons@v13/icons/linkedin.svg" alt="" loading="lazy" />
        </a>
        <a class="topbar__icon" href={`mailto:${profile.links.email}`} aria-label="Email">
          <img src="https://cdn.jsdelivr.net/npm/lucide-static@0.542.0/icons/mail.svg" alt="" loading="lazy" />
        </a>
        <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch to dark mode" aria-pressed="false">
          <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">
            <img src="https://cdn.jsdelivr.net/npm/lucide-static@0.542.0/icons/moon.svg" alt="" loading="lazy" />
          </span>
          <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">
            <img src="https://cdn.jsdelivr.net/npm/lucide-static@0.542.0/icons/sun.svg" alt="" loading="lazy" />
          </span>
        </button>
        <a class="topbar__resume" href={resumeHref} target="_blank" rel="noreferrer">
          Resume
        </a>
      </div>
    </header>

    <section class="hero" id="top">
      <div class="hero__copy" data-reveal="hero-left">
        <p class="eyebrow">DevOps · SRE · Platform engineering</p>
        <h1>Safer delivery for production systems.</h1>
        <p class="hero__lede">
          I build Kubernetes platforms, GitOps promotion paths, and infrastructure guardrails that let
          teams move faster without making production fragile.
        </p>
        <p class="hero__sublede">
          Recent work spans 2-minute config-only deploys, chaos-gated promotion on GKE, cluster trust
          policy, and stateful recovery work shaped by real incidents.
        </p>
        <div class="hero__actions">
          <a class="button button--primary" href="#work">Selected work</a>
          <a class="button button--ghost" href={resumeHref} target="_blank" rel="noreferrer">
            Resume
          </a>
        </div>
        <div class="hero__badge-row">
          <span class="status-pill status-pill--live">
            <span class="status-pill__dot"></span>
            Open to platform / SRE roles
          </span>
        </div>
        <div class="ops-strip" aria-label="Operational focus areas">
          {operationalSignals.map((signal) => (
            <span>{signal}</span>
          ))}
        </div>
        <dl class="stat-row">
          {impactSignals.map((signal) => (
            <div class="stat">
              <dt>{signal.label}</dt>
              <dd data-countup>{signal.value}</dd>
              <p>{signal.note}</p>
            </div>
          ))}
        </dl>
      </div>

      <div class="hero__visual" data-reveal="hero-right" data-delay="90">
        <ArtifactCollage photoSrc={profilePhoto.src} />
      </div>
    </section>

    <section class="section about" id="about">
      <div class="section-intro" data-reveal>
        <p class="eyebrow">About Me</p>
        <h2>I work in the messy layer between shipping code and keeping production calm.</h2>
      </div>

      <div class="about-grid">
        <article class="about-card surface" data-reveal data-delay="40">
          <p class="project-label">How I work</p>
          <p>
            I build the release paths, cluster guardrails, and identity layers that let teams ship
            without treating production like a gamble.
          </p>
          <p>
            I care less about the tools than about what they actually change. Does this promotion
            rule prevent a bad deploy from reaching prod? Does a rollback take seconds or minutes?
            If a platform change doesn't move one of those needles, it probably isn't finished.
          </p>
        </article>

        <article class="about-card surface" data-reveal data-delay="90">
          <p class="project-label">Best fit</p>
          <div class="about-points">
            {aboutHighlights.map((item) => <p>{item}</p>)}
          </div>
          <div class="about-tags">
            <span class="status-pill">Kubernetes</span>
            <span class="status-pill">GitOps</span>
            <span class="status-pill">Reliability</span>
            <span class="status-pill">Infrastructure</span>
          </div>
        </article>
      </div>
    </section>

    <section class="section" id="work">
      <div class="section-intro" data-reveal data-delay="40">
        <p class="eyebrow">Selected work</p>
        <h2>Platform work with real operational proof, not just tooling screenshots.</h2>
      </div>

      <article class="flagship surface" data-reveal data-delay="80">
        <div class="flagship__header">
          <div>
            <p class="project-label">Flagship project</p>
            <h3>{flagship.title}</h3>
          </div>
          {flagship.github && <p class="repo-meta">Updated {formatRepoTimestamp(flagship.github.updatedAt)}</p>}
        </div>

        <p class="flagship__summary">{flagship.summary}</p>
        <p class="flagship__hint">Preview only. Open the full case study for the release gate, dashboard evidence, and rollout decisions.</p>

        <div class="flagship__preview">
          <div class="flagship__artifact">
            <p class="project-label">Why it matters</p>
            <ul class="flagship__artifact-list">
              {flagship.proofPoints.slice(0, 2).map((point) => <li>{point}</li>)}
            </ul>
          </div>
          <figure class="gallery-card flagship__preview-card">
            <img src={grafanaSettlement.src} alt="Grafana dashboard showing payment settlement outcomes and end-to-end latency." />
            <figcaption>Settlement health and latency traces from the payment flow.</figcaption>
          </figure>
        </div>

        <div class="project-card__footer project-card__footer--flagship">
          <div class="project-tile__actions">
            <button
              class="button button--primary project-tile__button"
              type="button"
              data-project-open={`dialog-${flagship.id}`}
              aria-haspopup="dialog"
              aria-controls={`dialog-${flagship.id}`}
            >
              Open case study
            </button>
            {flagship.repo && (
              <a class="text-link" href={`https://github.com/${flagship.repo}`} target="_blank" rel="noreferrer">
                View repository
              </a>
            )}
          </div>

          <div class="chip-list">
            {flagship.stack.slice(0, 6).map((item) => (
              <span class="chip">
                {toolIconMap[item] && <img src={toolIconMap[item]} alt="" loading="lazy" />}
                {item}
              </span>
            ))}
          </div>
        </div>
      </article>

      <dialog class="project-dialog" id={`dialog-${flagship.id}`} data-project-dialog>
        <article class="project-dialog__panel">
          <button class="project-dialog__close" type="button" aria-label="Close project details" data-project-close>
            <span aria-hidden="true">×</span>
          </button>
          <div class="project-dialog__header">
            <div>
              <p class="project-label">Flagship project</p>
              <h3>{flagship.title}</h3>
            </div>
            {flagship.github && <p class="repo-meta">Updated {formatRepoTimestamp(flagship.github.updatedAt)}</p>}
          </div>

          <p class="project-dialog__summary">{flagship.summary}</p>

          <div class="project-dialog__grid">
            <section class="project-dialog__section">
              <p class="project-label">Why it matters</p>
              <ul class="flagship__artifact-list">
                {flagship.proofPoints.map((point) => <li>{point}</li>)}
              </ul>
            </section>
            <section class="project-dialog__section">
              <p class="project-label">Approach</p>
              <p>{flagship.approach}</p>
            </section>
          </div>

          <section class="project-dialog__section project-dialog__section--impact">
            <p class="project-label">Differentiator</p>
            <p>
              This is the only publicly documented implementation of Chaos Mesh wired as a Kargo
              promotion gate. It also carries a real protocol migration - replacing a custom
              receipt-polling path with x402/Permit2 through the Radius facilitator, which cut p95
              from 1.8s to 700ms and reduced failure modes from 9 to 6.
            </p>
          </section>

          <div class="flagship__gallery">
            <figure class="gallery-card gallery-card--large">
              <img src={grafanaSettlement.src} alt="Grafana dashboard showing payment settlement outcomes and end-to-end latency." />
              <figcaption>Settlement health and latency traces from the payment flow.</figcaption>
            </figure>
            <figure class="gallery-card">
              <img src={grafanaOverview.src} alt="Grafana dashboard showing request rates, p95 latency, and response code distribution." />
              <figcaption>Application overview across request rate, latency, and response codes.</figcaption>
            </figure>
            <figure class="gallery-card">
              <img src={grafanaSigner.src} alt="Grafana dashboard showing Permit2 signer success rate and duration." />
              <figcaption>Signer health and wallet balance across load test runs.</figcaption>
            </figure>
          </div>

          <div class="chip-list">
            {flagship.stack.map((item) => (
              <span class="chip">
                {toolIconMap[item] && <img src={toolIconMap[item]} alt="" loading="lazy" />}
                {item}
              </span>
            ))}
          </div>

          <div class="project-dialog__actions">
            {flagship.repo && (
              <a class="button button--primary" href={`https://github.com/${flagship.repo}`} target="_blank" rel="noreferrer">
                View repository
              </a>
            )}
          </div>
        </article>
      </dialog>

      <div class="project-list">
        {supportingProjects.map((project, index) => (
          <article class="project-tile surface" data-reveal data-delay={120 + index * 70}>
            <div class="project-tile__header">
              <div>
                <p class="project-label">{project.status}</p>
                <h3>{project.title}</h3>
              </div>
              {project.github && <p class="repo-meta">Updated {formatRepoTimestamp(project.github.updatedAt)}</p>}
            </div>
            <p class="project-tile__summary">{project.summary}</p>
            <p class="project-tile__hint">Short version here. Open the case study for the full decisions, tradeoffs, and operational context.</p>
            <div class="project-tile__proof">
              {project.proofPoints.slice(0, 1).map((point) => <p>{point}</p>)}
            </div>
            <div class="project-card__footer">
              <div class="project-tile__actions">
                <button
                  class="button button--primary project-tile__button"
                  type="button"
                  data-project-open={`dialog-${project.id}`}
                  aria-haspopup="dialog"
                  aria-controls={`dialog-${project.id}`}
                >
                  Open case study
                </button>
                {project.repo && (
                  <a class="text-link" href={`https://github.com/${project.repo}`} target="_blank" rel="noreferrer">
                    View repository
                  </a>
                )}
              </div>
              <div class="chip-list">
                {project.stack.slice(0, 4).map((item) => (
                  <span class="chip">
                    {toolIconMap[item] && <img src={toolIconMap[item]} alt="" loading="lazy" />}
                    {item}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>

      {supportingProjects.map((project) => (
        <dialog class="project-dialog" id={`dialog-${project.id}`} data-project-dialog>
          <article class="project-dialog__panel">
            <button class="project-dialog__close" type="button" aria-label="Close project details" data-project-close>
              <span aria-hidden="true">×</span>
            </button>
            <div class="project-dialog__header">
              <div>
                <p class="project-label">{project.status}</p>
                <h3>{project.title}</h3>
              </div>
              {project.github && <p class="repo-meta">Updated {formatRepoTimestamp(project.github.updatedAt)}</p>}
            </div>
            <p class="project-dialog__summary">{project.summary}</p>

            {project.id === "k8s-supply-chain-security" && (
              <div class="project-dialog__artifact project-tile__artifact project-tile__artifact--policy" aria-label="Supply chain verification flow">
                <div class="policy-flow">
                  <div class="policy-node">
                    <span class="policy-node__eyebrow">CI</span>
                    <strong>GitHub Actions</strong>
                    <span>build + sign + attest</span>
                  </div>
                  <div class="policy-node policy-node--compact">
                    <span class="policy-node__eyebrow">Artifact</span>
                    <strong>Image + SBOM</strong>
                    <span>Cosign + Syft</span>
                  </div>
                  <div class="policy-node">
                    <span class="policy-node__eyebrow">Admission</span>
                    <strong>Kyverno</strong>
                    <span>verify trust at deploy time</span>
                  </div>
                </div>
                <div class="policy-outcomes">
                  <span class="policy-outcome policy-outcome--allow">signed / attested -> allow</span>
                  <span class="policy-outcome policy-outcome--block">unsigned / mutable -> block</span>
                </div>
              </div>
            )}

            {supportingArtifacts[project.id] && (
              <figure class="project-dialog__artifact project-tile__artifact">
                <img src={supportingArtifacts[project.id].src} alt={supportingArtifacts[project.id].alt} />
                <figcaption>{supportingArtifacts[project.id].caption}</figcaption>
              </figure>
            )}

            <div class="project-dialog__grid">
              <section class="project-dialog__section">
                <p class="project-label">Problem</p>
                <p>{project.problem}</p>
              </section>
              <section class="project-dialog__section">
                <p class="project-label">Approach</p>
                <p>{project.approach}</p>
              </section>
            </div>

            <section class="project-dialog__section project-dialog__section--impact">
              <p class="project-label">Impact</p>
              <p>{project.impact}</p>
            </section>

            <div class="project-dialog__proof">
              {project.proofPoints.map((point) => <p>{point}</p>)}
            </div>

            <div class="chip-list">
              {project.stack.map((item) => (
                <span class="chip">
                  {toolIconMap[item] && <img src={toolIconMap[item]} alt="" loading="lazy" />}
                  {item}
                </span>
              ))}
            </div>

            <div class="project-dialog__actions">
              {project.repo && (
                <a class="button button--primary" href={`https://github.com/${project.repo}`} target="_blank" rel="noreferrer">
                  View repository
                </a>
              )}
              {project.github?.homepage && (
                <a class="button button--ghost" href={project.github.homepage} target="_blank" rel="noreferrer">
                  Open live project
                </a>
              )}
            </div>
          </article>
        </dialog>
      ))}
    </section>

    <section class="section" id="experience">
      <div class="section-intro" data-reveal>
        <p class="eyebrow">Experience</p>
        <h2>Experience shaping release safety, migration speed, and infrastructure reliability.</h2>
      </div>

      <div class="case-list">
        {caseStudyEntries.map((entry, index) => (
          <article class="case surface" data-reveal data-delay={index * 70}>
            <div class="case__header">
              <div>
                <p class="project-label">{entry.data.company}</p>
                <h3>{entry.data.role}</h3>
              </div>
              <p class="repo-meta">{entry.data.period}</p>
            </div>

            <p class="case__summary">{entry.data.challenge}</p>

            <div class="case__results">
              {entry.data.results.slice(0, 3).map((result) => <p>{result}</p>)}
            </div>

            <div class="chip-list">
              {entry.data.tools.slice(0, 6).map((tool) => <span class="chip">{tool}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="stack">
      <div class="section-intro" data-reveal>
        <p class="eyebrow">Tech Stack</p>
        <h2>The tools I reach for when the job is safer deploys, better cluster operations, and fewer production surprises.</h2>
      </div>

        <div class="stack-grid">
          {compactSkills.map((domain, index) => (
            <article class="stack-card" data-reveal data-delay={index * 45}>
              <div class="stack-card__header">
                {domain.domainIcon && <img src={domain.domainIcon} alt="" loading="lazy" />}
                <h3>{domain.name}</h3>
              </div>
              <p>{domain.summary}</p>
              <div class="stack-card__tools">
              {domain.tools.map((tool) => (
                <span>
                  {tool.icon && <img src={tool.icon} alt="" loading="lazy" />}
                  {tool.name}
                </span>
              ))}
              </div>
            </article>
          ))}
        </div>
    </section>

    <section class="section" id="writing">
      <div class="section-intro" data-reveal>
        <p class="eyebrow">Platform Notes</p>
        <h2>Notes from the parts of platform work that are easier to build than to explain.</h2>
      </div>

      <div class="writing-grid">
        {writingNotes.map((item, index) => (
          <article class="writing-card surface" data-reveal data-delay={index * 60}>
            <div class="writing-card__topline">
              <p class="project-label">{item.label}</p>
              <span class={`status-pill ${item.tone === "live" ? "status-pill--live" : ""}`}>
                {item.tone}
              </span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            {item.href ? (
              <a class="button button--primary writing-card__cta" href={item.href} target="_blank" rel="noreferrer">
                {item.cta}
              </a>
            ) : (
              <span class="writing-card__status">{item.status}</span>
            )}
          </article>
        ))}
      </div>
    </section>

    <section class="section section--contact" id="contact">
      <div class="contact-card" data-reveal>
        <div class="contact-card__identity">
          <p class="project-label">Amogh Jayasimha</p>
          <h3>Platform / SRE engineer building reliable delivery systems.</h3>
        </div>
        <div class="contact-card__body">
          <p class="eyebrow">Get in touch</p>
          <h2>Open to platform, SRE, and infrastructure roles.</h2>
          <p>
            Best fit: teams where platform work needs to hold up under change, failure, and real
            production load.
          </p>
        </div>
        <div class="contact-links contact-links--stacked">
          <a class="contact-link contact-link--primary" href={`mailto:${profile.links.email}`}>
            <span class="contact-link__mark">
              <img src="https://cdn.jsdelivr.net/npm/lucide-static@0.542.0/icons/mail.svg" alt="" loading="lazy" />
            </span>
            <span class="contact-link__text">
              <strong>Email</strong>
              <small>{profile.links.email}</small>
            </span>
          </a>
          <a class="contact-link" href={profile.links.linkedin} target="_blank" rel="noreferrer">
            <span class="contact-link__mark">
              <img src="https://cdn.jsdelivr.net/npm/simple-icons@v13/icons/linkedin.svg" alt="" loading="lazy" />
            </span>
            <span class="contact-link__text">
              <strong>LinkedIn</strong>
              <small>professional profile</small>
            </span>
          </a>
          <a class="contact-link" href={profile.links.github} target="_blank" rel="noreferrer">
            <span class="contact-link__mark">
              <img src="https://cdn.jsdelivr.net/npm/simple-icons@v13/icons/github.svg" alt="" loading="lazy" />
            </span>
            <span class="contact-link__text">
              <strong>GitHub</strong>
              <small>projects and code</small>
            </span>
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
