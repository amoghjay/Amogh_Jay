---
import type { RepoSnapshot } from "../lib/github";
import { formatRepoTimestamp } from "../lib/github";

interface Props {
  title: string;
  summary: string;
  problem: string;
  approach: string;
  impact: string;
  stack: string[];
  status: string;
  proofPoints: string[];
  github?: RepoSnapshot | null;
  repo?: string | null;
}

const { title, summary, problem, approach, impact, stack, status, proofPoints, github = null, repo = null } =
  Astro.props;
---

<article class="project-card surface">
  <div class="project-card__top">
    <div>
      <p class="project-card__status">{status}</p>
      <h3>{title}</h3>
    </div>
    {github && (
      <div class="repo-signal">
        <span>{github.stars} stars</span>
        <span>{github.forks} forks</span>
      </div>
    )}
  </div>

  <p class="project-card__summary">{summary}</p>

  <dl class="project-card__details">
    <div>
      <dt>Problem</dt>
      <dd>{problem}</dd>
    </div>
    <div>
      <dt>Approach</dt>
      <dd>{approach}</dd>
    </div>
    <div>
      <dt>Impact</dt>
      <dd>{impact}</dd>
    </div>
  </dl>

  <ul class="proof-points">
    {proofPoints.map((point) => <li>{point}</li>)}
  </ul>

  <div class="chip-list">
    {stack.map((item) => <span class="chip">{item}</span>)}
  </div>

  <div class="project-card__footer">
    {github ? (
      <p class="repo-meta">
        {github.language ?? "Multi-language"} · Updated {formatRepoTimestamp(github.updatedAt)}
      </p>
    ) : (
      <p class="repo-meta">Private or unpublished repository metadata intentionally omitted.</p>
    )}

    {repo && (
      <a class="text-link" href={`https://github.com/${repo}`} target="_blank" rel="noreferrer">
        View repository
      </a>
    )}
  </div>
</article>
