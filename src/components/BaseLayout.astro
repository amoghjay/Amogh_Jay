---
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8f2ea" data-theme-color />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Manrope:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,400;6..72,600;6..72,700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const storageKey = "amoghjay-theme";
        const getSystemTheme = () =>
          window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";

        try {
          const storedTheme = window.localStorage.getItem(storageKey);
          document.documentElement.dataset.theme = storedTheme || getSystemTheme();
        } catch {
          document.documentElement.dataset.theme = getSystemTheme();
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true">
      <div class="scroll-progress__bar" data-scroll-progress></div>
    </div>
    <slot />
    <script is:inline>
      (() => {
        const storageKey = "amoghjay-theme";

        const getSystemTheme = () =>
          window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";

        const getStoredTheme = () => {
          try {
            return window.localStorage.getItem(storageKey);
          } catch {
            return null;
          }
        };

        const setStoredTheme = (theme) => {
          try {
            window.localStorage.setItem(storageKey, theme);
          } catch {
            // Theme preference is an enhancement; ignore storage failures.
          }
        };

        const applyTheme = (theme, { persist = false } = {}) => {
          const nextTheme = theme === "dark" ? "dark" : "light";
          document.documentElement.dataset.theme = nextTheme;
          if (persist) setStoredTheme(nextTheme);

          const metaThemeColor = document.querySelector("[data-theme-color]");
          if (metaThemeColor) {
            metaThemeColor.setAttribute("content", nextTheme === "dark" ? "#091018" : "#f8f2ea");
          }

          document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
            const isDark = nextTheme === "dark";
            button.setAttribute("aria-pressed", String(isDark));
            button.setAttribute("aria-label", isDark ? "Switch to light mode" : "Switch to dark mode");
          });
        };

        const setupThemeToggle = () => {
          const initialTheme = getStoredTheme() || document.documentElement.dataset.theme || getSystemTheme();
          applyTheme(initialTheme);

          document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
            if (button.dataset.themeReady === "true") return;
            button.dataset.themeReady = "true";
            button.addEventListener("click", () => {
              const currentTheme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
              applyTheme(currentTheme === "dark" ? "light" : "dark", { persist: true });
            });
          });
        };

        const setupScrollProgress = () => {
          const bar = document.querySelector("[data-scroll-progress]");
          if (!bar) return;

          const update = () => {
            const max = document.documentElement.scrollHeight - window.innerHeight;
            const progress = max > 0 ? Math.min(window.scrollY / max, 1) : 0;
            bar.style.width = `${progress * 100}%`;
          };

          if (document.body.dataset.scrollProgressReady === "true") {
            update();
            return;
          }

          document.body.dataset.scrollProgressReady = "true";
          window.addEventListener("scroll", update, { passive: true });
          window.addEventListener("resize", update);
          update();
        };

        const setupReveals = () => {
          const nodes = document.querySelectorAll("[data-reveal]");
          if (!nodes.length) return;

          if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
            nodes.forEach((node) => node.classList.add("is-visible"));
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              });
            },
            {
              threshold: 0.16,
              rootMargin: "0px 0px -8% 0px"
            }
          );

          nodes.forEach((node) => {
            if (node.dataset.revealReady === "true") return;
            node.dataset.revealReady = "true";
            if (node.dataset.delay) {
              node.style.setProperty("--reveal-delay", `${node.dataset.delay}ms`);
            }
            observer.observe(node);
          });
        };

        const setupActiveNav = () => {
          const sections = [...document.querySelectorAll("section[id]")];
          const links = [...document.querySelectorAll("[data-nav-link]")];
          if (!sections.length || !links.length) return;

          const byId = new Map(links.map((link) => [link.getAttribute("data-nav-link"), link]));

          const setActive = (id) => {
            links.forEach((link) => link.removeAttribute("data-active"));
            const active = byId.get(id);
            if (active) active.setAttribute("data-active", "true");
          };

          const updateActive = () => {
            const marker = window.innerHeight * 0.28;
            let currentId = sections[0]?.getAttribute("id") ?? null;

            sections.forEach((section) => {
              const rect = section.getBoundingClientRect();
              if (rect.top <= marker && rect.bottom >= marker) {
                currentId = section.getAttribute("id");
              }
            });

            if (currentId) setActive(currentId);
          };

          let ticking = false;
          const requestUpdate = () => {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(() => {
              updateActive();
              ticking = false;
            });
          };

          window.addEventListener("scroll", requestUpdate, { passive: true });
          window.addEventListener("resize", requestUpdate);
          updateActive();
        };

        const setupCountups = () => {
          const items = document.querySelectorAll("[data-countup]");
          if (!items.length) return;

          if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
            return;
          }

          const parseValue = (value) => {
            const hasPercent = value.includes("%");
            const hasPlus = value.includes("+");
            const hasX = value.toLowerCase().includes("x");
            const numeric = parseFloat(value.replace(/[^0-9.]/g, ""));
            return { numeric, hasPercent, hasPlus, hasX };
          };

          const formatValue = ({ numeric, hasPercent, hasPlus, hasX }, current) => {
            if (hasX) return `${current.toFixed(1)}x`;
            const rounded = Number.isInteger(numeric) ? Math.round(current).toString() : current.toFixed(1);
            if (hasPercent) return `${rounded}%`;
            if (hasPlus) return `${rounded}+`;
            return rounded;
          };

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                const node = entry.target;
                if (node.dataset.counted === "true") return;
                node.dataset.counted = "true";

                const original = node.textContent?.trim() ?? "";
                const meta = parseValue(original);
                if (!meta.numeric) return;

                const start = performance.now();
                const duration = 900;

                const tick = (now) => {
                  const progress = Math.min((now - start) / duration, 1);
                  const eased = 1 - Math.pow(1 - progress, 3);
                  const current = meta.numeric * eased;
                  node.textContent = formatValue(meta, current);
                  if (progress < 1) requestAnimationFrame(tick);
                };

                requestAnimationFrame(tick);
                observer.unobserve(node);
              });
            },
            { threshold: 0.45 }
          );

          items.forEach((item) => observer.observe(item));
        };

        const setupLanePulse = () => {
          const lane = document.querySelector(".artifact__lane");
          if (!lane || lane.dataset.laneReady === "true") return;

          lane.dataset.laneReady = "true";
          const steps = [...lane.querySelectorAll("[data-lane-step]")];
          if (!steps.length) return;

          if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
            steps[0]?.setAttribute("data-live", "true");
            return;
          }

          let timer = null;
          let index = 0;

          const activate = (activeIndex) => {
            steps.forEach((step, stepIndex) => {
              if (stepIndex === activeIndex) {
                step.setAttribute("data-live", "true");
              } else {
                step.removeAttribute("data-live");
              }
            });
          };

          const start = () => {
            if (timer) return;
            activate(index);
            timer = window.setInterval(() => {
              index = (index + 1) % steps.length;
              activate(index);
            }, 1350);
          };

          const stop = () => {
            if (timer) {
              window.clearInterval(timer);
              timer = null;
            }
            steps.forEach((step) => step.removeAttribute("data-live"));
          };

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  start();
                } else {
                  stop();
                }
              });
            },
            { threshold: 0.35 }
          );

          observer.observe(lane);
        };

        const setupProjectDialogs = () => {
          const dialogs = [...document.querySelectorAll("[data-project-dialog]")];
          const openers = [...document.querySelectorAll("[data-project-open]")];
          if (!dialogs.length || !openers.length) return;

          if (document.body.dataset.projectDialogsReady !== "true") {
            document.body.dataset.projectDialogsReady = "true";
            const openerMap = new WeakMap();

            openers.forEach((opener) => {
              opener.addEventListener("click", () => {
                const targetId = opener.getAttribute("data-project-open");
                if (!targetId) return;
                const dialog = document.getElementById(targetId);
                if (!(dialog instanceof HTMLDialogElement)) return;
                openerMap.set(dialog, opener);
                opener.setAttribute("aria-expanded", "true");
                document.body.style.overflow = "hidden";
                dialog.showModal();
                requestAnimationFrame(() => {
                  const closeButton = dialog.querySelector("[data-project-close]");
                  if (closeButton instanceof HTMLElement) {
                    closeButton.focus();
                  }
                });
              });
            });

            dialogs.forEach((dialog) => {
              if (!(dialog instanceof HTMLDialogElement)) return;

              dialog.addEventListener("click", (event) => {
                const panel = dialog.querySelector(".project-dialog__panel");
                if (panel && !panel.contains(event.target)) {
                  dialog.close();
                }
              });

              dialog.querySelectorAll("[data-project-close]").forEach((button) => {
                button.addEventListener("click", () => dialog.close());
              });

              dialog.addEventListener("close", () => {
                document.body.style.removeProperty("overflow");
                const opener = openerMap.get(dialog);
                if (opener instanceof HTMLElement) {
                  opener.setAttribute("aria-expanded", "false");
                  opener.focus();
                }
              });

              dialog.addEventListener("cancel", () => {
                document.body.style.removeProperty("overflow");
              });
            });
          }
        };

        document.addEventListener("DOMContentLoaded", setupThemeToggle);
        document.addEventListener("DOMContentLoaded", setupScrollProgress);
        document.addEventListener("DOMContentLoaded", setupReveals);
        document.addEventListener("DOMContentLoaded", setupActiveNav);
        document.addEventListener("DOMContentLoaded", setupCountups);
        document.addEventListener("DOMContentLoaded", setupLanePulse);
        document.addEventListener("DOMContentLoaded", setupProjectDialogs);
        document.addEventListener("astro:page-load", setupThemeToggle);
        document.addEventListener("astro:page-load", setupScrollProgress);
        document.addEventListener("astro:page-load", setupReveals);
        document.addEventListener("astro:page-load", setupActiveNav);
        document.addEventListener("astro:page-load", setupCountups);
        document.addEventListener("astro:page-load", setupLanePulse);
        document.addEventListener("astro:page-load", setupProjectDialogs);
      })();
    </script>
  </body>
</html>
