---
interface Props {
  company: string;
  role: string;
  period: string;
  challenge: string;
  actions: string[];
  results: string[];
  tools: string[];
}

const { company, role, period, challenge, actions, results, tools } = Astro.props;
---

<article class="case-study surface">
  <div class="case-study__header">
    <div>
      <p class="eyebrow">{company}</p>
      <h3>{role}</h3>
    </div>
    <p class="case-study__period">{period}</p>
  </div>

  <p class="case-study__challenge">{challenge}</p>

  <div class="case-study__grid">
    <div>
      <h4>What changed</h4>
      <ul>
        {actions.map((action) => <li>{action}</li>)}
      </ul>
    </div>
    <div>
      <h4>Results</h4>
      <ul>
        {results.map((result) => <li>{result}</li>)}
      </ul>
    </div>
  </div>

  <div class="chip-list">
    {tools.map((tool) => <span class="chip">{tool}</span>)}
  </div>
</article>
